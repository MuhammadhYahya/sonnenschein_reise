generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InquiryStatus {
  NEW
  REVIEWED
  CONTACTED
  QUALIFIED
  CLOSED
}

enum BookingStatus {
  DRAFT
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum StaffRole {
  OWNER
  ADMIN
  AGENT
  EDITOR
}

model User {
  id        String      @id @default(cuid())
  email     String      @unique
  fullName  String
  role      StaffRole   @default(EDITOR)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  adminNotes AdminNote[]
}

model Inquiry {
  id                String        @id @default(cuid())
  fullName          String
  email             String
  phone             String?
  country           String?
  preferredLanguage String?
  requestedTourSlug String?
  requestedDuration String?
  travelerCount     Int?
  travelMonth       String?
  message           String
  status            InquiryStatus @default(NEW)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  booking           Booking?
  notes             AdminNote[]
}

model Tour {
  id             String      @id @default(cuid())
  slug           String      @unique
  internalName   String
  isActive       Boolean     @default(true)
  basePriceCents Int?
  currency       String      @default("USD")
  departures     Departure[]
  bookings       Booking[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Departure {
  id             String    @id @default(cuid())
  tourId         String
  startDate      DateTime
  endDate        DateTime
  capacity       Int
  remainingSpots Int
  tour           Tour      @relation(fields: [tourId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Booking {
  id                String        @id @default(cuid())
  inquiryId         String?       @unique
  tourId            String
  departureId       String?
  leadTravelerName  String
  leadTravelerEmail String
  travelerCount     Int
  totalAmountCents  Int
  currency          String        @default("USD")
  status            BookingStatus @default(DRAFT)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  inquiry           Inquiry?      @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  tour              Tour          @relation(fields: [tourId], references: [id], onDelete: Restrict)
  departure         Departure?    @relation(fields: [departureId], references: [id], onDelete: SetNull)
  travelers         Traveler[]
  payments          Payment[]
  notes             AdminNote[]
}

model Traveler {
  id             String   @id @default(cuid())
  bookingId      String
  fullName       String
  birthDate      DateTime?
  passportNumber String?
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Payment {
  id          String   @id @default(cuid())
  bookingId   String
  provider    String
  providerRef String?
  amountCents Int
  currency    String   @default("USD")
  status      String
  paidAt      DateTime?
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminNote {
  id        String   @id @default(cuid())
  body      String
  userId    String?
  inquiryId String?
  bookingId String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  inquiry   Inquiry? @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
